# OpenTelemetry Instrumentation Configuration
# This file is used by docker-compose.otel-collector-extension.yml

# Required for opentelemetry-instrument to configure Django correctly
DJANGO_SETTINGS_MODULE=coldfront.config.settings

# Service name (required for SDK initialization)
OTEL_SERVICE_NAME=coldfront

# Resource attributes
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=dev

# Enable OTLP exporter to send traces to collector (and then to Jaeger)
# Note: docker-compose.jaeger-extension.yml also sets these, but we set them here
# for consistency and to ensure they work regardless of compose file merge order
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

# OTLP Protocol (grpc for port 4317, http/protobuf for port 4318)
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# OTLP Collector endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Enable logging instrumentation
OTEL_PYTHON_LOGGING_AUTO_INSTRUMENTATION_ENABLED=true

# Enable debug logging for OpenTelemetry
OTEL_LOG_LEVEL=debug
